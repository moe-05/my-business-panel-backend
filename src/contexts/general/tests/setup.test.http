### FASE 1 — CORE: TENANT + BRANCH + USER
### ============================================================

### 1.1 Crear tenant
### → Guardar tenant_id en @tenantId
POST {{baseUrl}}/tenant
Content-Type: application/json

{
  "tenant_name": "Distribuidora Demo S.A.",
  "contact_email": "demo@distribuidora.cr",
  "region_id": 1,
  "identification": "3101234567",
  "economic_activity": "742101",
  "sign": "DDS",
  "is_subscribed": true
}

###

### 1.2 Crear sucursal principal
### → Guardar branch_id en @branchId
POST {{baseUrl}}/branch
Content-Type: application/json

{
  "tenant_id": "{{tenantId}}",
  "branch_name": "Sucursal Central",
  "branch_number": "001",
  "address": "San José, Costa Rica",
  "contact_email": "central@distribuidora.cr",
  "is_main_branch": true
}

###

### 1.3 Crear segunda sucursal (para transferencias)
### → Guardar branch_id en @branchId2
POST {{baseUrl}}/branch
Content-Type: application/json

{
  "tenant_id": "{{tenantId}}",
  "branch_name": "Sucursal Norte",
  "branch_number": "002",
  "address": "Heredia, Costa Rica",
  "contact_email": "norte@distribuidora.cr",
  "is_main_branch": false
}

###

### 1.4 Crear turno de trabajo
### → Guardar turn_id en @turnId
POST {{baseUrl}}/turns
Content-Type: application/json

{
  "branchId": "{{branchId}}",
  "entry": "08:00",
  "out": "17:00"
}

###

### 1.5 Crear usuario administrador
### → Guardar user_id en @userId
### → Guardar employee_id en @employeeId
POST {{baseUrl}}/user
Content-Type: application/json

{
  "tenant_id": "{{tenantId}}",
  "email": "admin@distribuidora.cr",
  "password": "Admin1234!",
  "role_id": 1,
  "employeeInfo": {
    "tenant_id": "{{tenantId}}",
    "branch_id": "{{branchId}}",
    "first_name": "Carlos",
    "last_name": "Mora Solano",
    "doc_number": "106780000",
    "phone": "60001111",
    "email": "admin@distribuidora.cr",
    "payment_schedule_id": 1,
    "contractData": {
      "start_date": "2025-01-01",
      "end_date": "2026-12-31",
      "hours": 40,
      "base_salary": 800000,
      "duties": "Administración general",
      "turn_type": 1,
      "turn_id": "{{turnId}}"
    }
  }
}

###

### 1.6 Login
### → Sesión activa por cookie
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@distribuidora.cr",
  "password": "Admin1234!"
}

###


