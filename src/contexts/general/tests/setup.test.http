### FASE 6 — POS (VENTAS)
### ============================================================

### 6.1 Crear caja registradora
### → Guardar cash_register_id en @cashRegId
POST {{baseUrl}}/cash-register
Content-Type: application/json

{
  "branch_id": "{{branchId}}",
  "register_name": "Caja Principal",
  "is_active": true
}

###

### 6.2 Abrir sesión de caja
### → Guardar cash_register_session_id en @cashRegSessId
POST {{baseUrl}}/cash-register/start
Content-Type: application/json

{
  "cash_register_id": "{{cashRegId}}",
  "opening_amount": 100000,
  "opened_at": "2026-03-07T08:00:00.000Z"
}

###

### 6.3 Crear venta completa
### → Guardar sale_id en @saleId
### → Guardar sale_item_id del primer item en @saleItemId
### IVA 13%: subtotal 4500 + tax 585 = total 5085
POST {{baseUrl}}/sale
Content-Type: application/json

{
  "branch_id": "{{branchId}}",
  "currency_id": 1,
  "tenant_id": "{{tenantId}}",
  "tenant_customer_id": "{{customerId}}",
  "sale_condition": "01",
  "sale_date": "2026-03-07T10:30:00.000Z",
  "subtotal_amount": 4500.00,
  "tax_amount": 585.00,
  "total_amount": 5085.00,
  "is_completed": true,
  "has_electronic_invoice": false,
  "items": [
    {
      "tenant_id": "{{tenantId}}",
      "product_variant_id": "{{variantId}}",
      "quantity": 2,
      "unit_price": 1500.00,
      "total_price": 3000.00
    },
    {
      "tenant_id": "{{tenantId}}",
      "product_variant_id": "{{variantId2}}",
      "quantity": 3,
      "unit_price": 500.00,
      "total_price": 1500.00
    }
  ],
  "payments": [
    {
      "tenant_customer_id": "{{customerId}}",
      "payment_method_id": 1,
      "is_points_redemption": false,
      "points_redeemed": 0,
      "points_to_currency_rate": 0,
      "payment_amount": 5085.00,
