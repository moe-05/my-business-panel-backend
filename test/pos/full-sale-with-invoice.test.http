@customerId    = 5e4b2fdf-d9d8-4070-8df7-a3383c9afc7c
@variantId     = 5f8ac1a1-8e56-40fa-a39b-4e890f84e7b8
@saleId        = 6c5e1f02-7aff-497e-9cd8-553a27d27d0d
# ─── IDs para venta multi-ítem (FASE 10 y 11) ───────────────
@v02Id         = b9a1c870-b5cc-4ee4-892a-a10343ac3f99
@v03Id         = a432967c-0b74-401f-8a60-254cc614d55b
@v04Id         = 3a06a7a2-ba5c-4def-8882-d755439e293e
@v05Id         = aba16bdc-3be8-4209-999d-42729b1dbe7a
@v06Id         = 50621299-425d-48c2-ade6-42e6afae1e4c
@v07Id         = c15c7695-8c10-442c-9713-977d82a0c503
@v08Id         = e61e7688-b494-47cd-9e3d-592d2ab318d1
@v09Id         = 26f94180-510a-4f69-bfed-f574d2f4635f
@v10Id         = 08e7a6dc-946e-48ae-8356-c66431e105f8
