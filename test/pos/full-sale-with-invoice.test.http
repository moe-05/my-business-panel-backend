@multiSaleId   = 


### ============================================================
### FASE 0 — BOOTSTRAP (SQL directo, solo primera vez)
### ============================================================
### El primer usuario admin NO puede crearse via HTTP sin una
### sucursal preexistente, y la sucursal requiere sesión activa.
### Resolver ejecutando este SQL ANTES de los requests HTTP:
###
###   -- 1. Crear sucursal principal del tenant
###   INSERT INTO general_schema.branch
###     (tenant_id, branch_name, branch_number, is_main_branch)
###   VALUES
###     ('{{tenantId}}', 'Sucursal Central San José', '001', true)
###   RETURNING branch_id;
###   -- → copiar branch_id en @branchId
###
###   -- 2. Crear turno de trabajo para esa sucursal
###   INSERT INTO hr_schema.turn (branch_id, entry, out)
###   VALUES ('<branch_id>', '08:00', '17:00')
###   RETURNING turn_id;
###   -- → copiar turn_id en @turnId (normalmente 1 la primera vez)
###
### ============================================================


### ============================================================
### FASE 1 — CONFIGURACIÓN DEL TENANT
### ============================================================

### 1. Crear tenant
# Respuesta: { tenant_id, tenant_name, ... }
# → Guardar tenant_id en @tenantId
POST {{baseUrl}}/tenant
Content-Type: application/json

{
  "tenant_name": "Distribuidora Demo S.A.",
  "contact_email": "demo@distribuidora.cr",
  "region_id": 1,
  "identification": "3101234567",
  "economic_activity": "742101",
  "sign": "DDS",
  "is_subscribed": true
}


### ============================================================
### FASE 2 — USUARIO Y AUTENTICACIÓN
### ============================================================

### 2. Crear usuario administrador
# Sin guards activos — no requiere sesión previa.
# Requiere: @branchId y @turnId del bootstrap SQL (Fase 0).
# Respuesta: { user_id, ... }
POST {{baseUrl}}/user
Content-Type: application/json

{
  "tenant_id": "{{tenantId}}",
  "email": "admin@distribuidora.cr",
  "password": "Admin1234!",
  "role_id": 1,
  "employeeInfo": {
    "tenant_id": "{{tenantId}}",
    "branch_id": "{{branchId}}",
    "first_name": "Carlos",
    "last_name": "Mora",
    "doc_number": "106780000",
    "phone": "60001111",
    "email": "admin@distribuidora.cr",
    "payment_schedule_id": 1,
    "contractData": {
      "start_date": "2025-01-01",
      "end_date": "2026-01-01",
      "hours": 40,
      "base_salary": 500000,
      "duties": "Administración general",
      "turn_type": 1,
      "turn_id": {{turnId}}
    }
  }
}


### 3. Login
# Respuesta: cookie de sesión (se aplica automáticamente a requests siguientes)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@distribuidora.cr",
  "password": "Admin1234!"
}


### ============================================================
### FASE 3 — SUCURSAL ADICIONAL VÍA API (opcional)
### ============================================================

### 4. Crear sucursal adicional via API (requiere sesión nivel 3+)
# La sucursal principal ya fue creada en el bootstrap SQL.
# Este request es para crear sucursales adicionales.
# Respuesta: { branch_id, ... }
POST {{baseUrl}}/branch
Content-Type: application/json

{
  "tenant_id": "{{tenantId}}",
  "branch_name": "Sucursal Norte",
  "address": "Alajuela, Costa Rica",
  "contact_email": "norte@distribuidora.cr",
  "branch_number": "002",
  "is_main_branch": false
}


### 5. Crear caja registradora
# Requiere: sesión (nivel 4+)
# Respuesta: { cash_register_id, ... }
# → Guardar cash_register_id en @cashRegId
POST {{baseUrl}}/cash-register
Content-Type: application/json

{
  "branch_id": "{{branchId}}",
  "register_name": "Caja Principal",
  "is_active": true
}


### 6. Abrir sesión de caja
# Requiere: sesión (nivel 1+)
# Respuesta: { cash_register_session_id, ... }
# → Guardar cash_register_session_id en @cashRegSessId
POST {{baseUrl}}/cash-register/start
Content-Type: application/json

{
  "cash_register_id": "{{cashRegId}}",
  "userId": "{{userId}}",
  "opening_amount": 100000,
  "opened_at": "2025-06-01T08:00:00.000Z"
}


